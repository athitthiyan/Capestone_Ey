# Copy to .env.production on your production host and fill real values.

BACKEND_IMAGE=ghcr.io/owner/repo-backend:latest
UI_IMAGE=ghcr.io/owner/repo-ui:latest

POSTGRES_PASSWORD=replace-with-long-random-password
SECRET_KEY=replace-with-at-least-32-random-characters
ANTHROPIC_API_KEY=replace-with-anthropic-key
GROQ_API_KEY=
OPENAI_API_KEY=
DEFAULT_LLM_PROVIDER=anthropic
ENABLE_LLM_FALLBACK=true
LLM_FALLBACK_ORDER=groq,openai
LLM_PRICING_OVERRIDES_JSON=

NEXT_PUBLIC_API_BASE_URL=https://api.example.com/api/v1
CORS_ORIGINS=["https://app.example.com"]
ALLOWED_HOSTS=["api.example.com"]

API_PORT=8000
UI_PORT=3000
LOG_LEVEL=INFO
USE_EVENTSTORE=true
USE_REAL_AGENTS=true
REQUEST_LOGGING_ENABLED=true
REQUEST_LOG_EXCLUDED_PATHS=["/health","/health/detailed","/docs","/openapi.json","/favicon.ico"]

SEED_DEFAULT_USER=false
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_ROLE=partner
CELERY_WORKER_CONCURRENCY=4
