# Environment Configuration Template
# Copy this file to .env and fill in actual values

# Application
ENV=development
DEBUG=true
LOG_LEVEL=INFO
APP_NAME="Skeptic Engine Backend"
APP_VERSION=0.1.0

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_ROOT_PATH=/api/v1
# CORS_ORIGINS and ALLOWED_HOSTS should be JSON lists in .env files.
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
# Use "*" only in local dev. In prod list your real hostnames.
ALLOWED_HOSTS=["*"]

# Database
DATABASE_URL=postgresql://skeptic:skeptic_dev_password@localhost:5432/skeptic_engine
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# pgAdmin local UI (docker-compose service)
PGADMIN_URL=http://localhost:5050
PGADMIN_DEFAULT_EMAIL=admin@skeptic.local
PGADMIN_DEFAULT_PASSWORD=

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600
USE_REDIS_EVENTS=false
REDIS_SOCKET_TIMEOUT=0.25

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_TIMEZONE=UTC
# False runs investigations in the API process (best for local dev/tests).
# True dispatches to Celery workers and requires Redis + worker processes.
USE_CELERY=false

# EventStoreDB
USE_EVENTSTORE=false
EVENTSTORE_URL=esdb://localhost:2113?tls=false
EVENTSTORE_STREAM_PREFIX=investigations

# LLM providers
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
DEFAULT_LLM_PROVIDER=anthropic
ENABLE_LLM_FALLBACK=true
LLM_FALLBACK_ORDER=groq,openai
LLM_REQUEST_TIMEOUT_SECONDS=45
LLM_CACHE_ENABLED=true
LLM_CACHE_TTL_SECONDS=1800
LLM_MAX_PROMPT_TOKENS=18000
# JSON object keyed by model id, for example:
# {"gpt-4.1-mini":{"input_per_million":0.40,"output_per_million":1.60}}
LLM_PRICING_OVERRIDES_JSON=
CLAUDE_MODEL_REASONING=claude-sonnet-5
CLAUDE_MODEL_LIGHTWEIGHT=claude-haiku-4-5-20251001
GROQ_MODEL_REASONING=llama-3.3-70b-versatile
GROQ_MODEL_LIGHTWEIGHT=llama-3.1-8b-instant
OPENAI_MODEL_REASONING=gpt-4.1
OPENAI_MODEL_LIGHTWEIGHT=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_MODEL_REASONING=gemini-2.0-flash
GEMINI_MODEL_LIGHTWEIGHT=gemini-2.0-flash-lite
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL_REASONING=deepseek-reasoner
DEEPSEEK_MODEL_LIGHTWEIGHT=deepseek-chat
CLAUDE_MAX_TOKENS=4000
CLAUDE_TEMPERATURE=0.7
# Per-model sampling temperature (independent of each other).
ANTHROPIC_TEMPERATURE=0.3
GROQ_TEMPERATURE=0.2
OPENAI_TEMPERATURE=0.2
GEMINI_TEMPERATURE=0.3
DEEPSEEK_TEMPERATURE=0.2
# Set true to run real LLM agents (needs the selected DEFAULT_LLM_PROVIDER key).
# False uses deterministic stubs for local dev / CI.
USE_REAL_AGENTS=false

# Observability
# Prometheus metrics exposed at GET /metrics (scraped per k8s-deployment.yaml annotations).
METRICS_ENABLED=true
# LangSmith traces every LangChain/LangGraph agent call (requires an API key from smith.langchain.com).
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=skeptic-engine
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Security
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Set false to allow unauthenticated access during early local dev.
AUTH_REQUIRED=false
# Seeds an initial local admin only when the users table is empty.
SEED_DEFAULT_USER=false
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_ROLE=partner

# Audit
AUDIT_FALLBACK_TO_POSTGRES=true

# Investigation Defaults
DEFAULT_MATERIALITY_THRESHOLD=50000.0
DEFAULT_CONFIDENCE_THRESHOLD=0.7
DEFAULT_ESCALATION_THRESHOLD=0.5
MAX_DEBATE_ROUNDS=2
INVESTIGATION_TIMEOUT_MINUTES=30
ESTIMATED_AGENT_RUN_COST_USD=0.21

# Governance/UI defaults exposed through /settings.
ENFORCE_SEGREGATION_OF_DUTIES=true
IMMUTABLE_AUDIT_LOG_REQUIRED=true
API_KEY_VAULT_NAME=environment
UI_THEME=system
DISPLAY_CURRENCY=USD
NOTIFICATIONS_ENABLED=false
AUDIT_RETENTION_YEARS=7
IP_ALLOWLIST_ENABLED=false
REQUEST_LOGGING_ENABLED=true
REQUEST_LOG_EXCLUDED_PATHS=["/health","/health/detailed","/docs","/openapi.json","/favicon.ico"]

# External APIs
FX_API_BASE_URL=https://api.frankfurter.app
REGISTRY_API_BASE_URL=

# Third-party evidence verification
# Provider URLs must point at real third-party APIs or approved internal wrappers.
# Empty provider URLs return API_UNAVAILABLE; no benchmark amount is mocked.
EVIDENCE_VERIFICATION_PROVIDER_TIMEOUT_SECONDS=3.0
EVIDENCE_VERIFICATION_DEFAULT_TOLERANCE=0.30
EVIDENCE_VERIFICATION_FLIGHT_TOLERANCE=0.25
EVIDENCE_VERIFICATION_HOTEL_TOLERANCE=0.30
EVIDENCE_VERIFICATION_FOOD_TOLERANCE=0.30
EVIDENCE_VERIFICATION_CAB_TOLERANCE=0.25
EVIDENCE_VERIFICATION_FUEL_TOLERANCE=0.10
EVIDENCE_VERIFICATION_GST_TOLERANCE=0.0
# FX conversion tolerance (keyless Frankfurter provider, no key needed).
EVIDENCE_VERIFICATION_FX_TOLERANCE=0.02
FLIGHT_PRICE_PROVIDER_URL=
FLIGHT_PRICE_PROVIDER_API_KEY=
# Free-tier options you can plug in (leave blank to return API_UNAVAILABLE):
#   Hotel : Amadeus Self-Service (free test tier) - https://developers.amadeu
# --- Fuel: IndianAPI live fuel price (https://fuel.indianapi.in) ---
# Native adapter (x-api-key header). Get a key: indianapi.in > API Hub > Fuel
# Price API > Subscribe (free) > Dashboard > Manage Keys > Rotate Key.
FUEL_PRICE_PROVIDER_URL=https://fuel.indianapi.in
FUEL_PRICE_PROVIDER_API_KEY=
FUEL_PRICE_PROVIDER_HEADER=x-api-key
FUEL_PRICE_LIVE_PATH=/live_fuel_price
FUEL_PRICE_DEFAULT_TYPE=petrol

# --- Flight: Aviationstack route-existence validator (NOT fares) ---
# Confirms a route/airline is real via /routes. access_key query param.
# Get a key: aviationstack.com > free plan. Fares (price benchmark) need a
# separate fares API later (e.g. Kiwi Tequila) via FLIGHT_PRICE_PROVIDER_URL.
FLIGHT_VALIDATION_PROVIDER_URL=https://api.aviationstack.com/v1
FLIGHT_VALIDATION_API_KEY=
FLIGHT_VALIDATION_ROUTES_PATH=/routes

# --- GST: GSTINCheck native validity provider ---
# Path-based key: GET https://sheet.gstincheck.co.in/check/{API_KEY}/{GSTIN}
# Validity/identity check (Active=VERIFIED, cancelled/not found=FLAGGED). Not a price.
GST_VERIFICATION_PROVIDER_API_KEY=
GST_VERIFICATION_BASE_URL=https://sheet.gstincheck.co.in
GST_VERIFICATION_CHECK_PATH=/check

# --- Duffel: real fares (flights) + Duffel Stays (hotels) ---
# Bearer auth + Duffel-Version header. Test keys (duffel_test_...) return
# synthetic offers (GBP), not real market prices. Prices are FX-converted to the
# claim currency via Frankfurter. Flights need IATA codes; Stays need coordinates.
DUFFEL_API_KEY=
DUFFEL_API_BASE_URL=https://api.duffel.com
DUFFEL_API_VERSION=v2
DUFFEL_FLIGHTS_ENABLED=true
DUFFEL_STAYS_ENABLED=true
DUFFEL_SUPPLIER_TIMEOUT_MS=15000
DUFFEL_HTTP_TIMEOUT_SECONDS=25.0
