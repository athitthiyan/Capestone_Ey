# Backend API integration
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Option 1: use a pre-issued bearer token.
# NEXT_PUBLIC_API_TOKEN=

# Option 2: local development password flow. Do not expose shared production
# credentials through NEXT_PUBLIC_* variables.
NEXT_PUBLIC_API_USERNAME=admin
NEXT_PUBLIC_API_PASSWORD=admin12345
